# === Deployment / CDK ===
CDK_DEFAULT_REGION=ap-northeast-2
CDK_DEFAULT_ACCOUNT=123456789012

# === Frontend ===
VITE_API_BASE_URL=https://{api-gateway-id}.execute-api.{region}.amazonaws.com/prod
VITE_S3_REGION=ap-northeast-2
AMPLIFY_MONOREPO_APP_ROOT=frontend

# === Backend / Lambda ===
DYNAMODB_TABLE_NAME=ppt-jobs
S3_BUCKET_NAME=ppt-builder-bucket
STEP_FUNCTIONS_ARN=arn:aws:states:{region}:{account-id}:stateMachine:ppt-pipeline

# === Worker / Fargate ===
AI_ENGINE=bedrock
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
OPENAI_SECRET_NAME=
S3_BUCKET=ppt-builder-bucket
DYNAMODB_TABLE=ppt-jobs
